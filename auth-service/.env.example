NODE_ENV=development
PORT=4300

DB_HOST=localhost
DB_PORT=5433
DB_NAME=auth_service
DB_USER=postgres
DB_PASSWORD=postgres

CORS_ORIGIN=http://localhost:3000

# Must match backend's and frontend's JWT_SECRET/AUTH_COOKIE_NAME/REFRESH_COOKIE_NAME
# byte-for-byte — this service issues the tokens, backend's remaining
# claim/category/trip routes and frontend/proxy.ts both independently verify
# them. A mismatch fails safe (401 / redirect to login) but locks out every
# user if only one side is updated.
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRES_IN=1d
ACCESS_TOKEN_COOKIE_MAX_AGE_MS=86400000
AUTH_COOKIE_NAME=auth_token
REFRESH_COOKIE_NAME=refresh_token
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_COOKIE_MAX_AGE_MS=2592000000
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=30
RESET_TOKEN_EXPIRES_IN=10m
REGISTRATION_TOKEN_EXPIRES_IN=15m
ONBOARDING_TOKEN_EXPIRES_IN=10m

# communications-service (email/WhatsApp delivery) — see ../communications-service.
COMMUNICATIONS_SERVICE_URL=http://localhost:4200
COMMUNICATIONS_SERVICE_INTERNAL_API_KEY=

# Optional shared secret backend/claim-service send as X-Internal-Api-Key
# when calling this service's /internal/* routes. Leave unset locally to
# skip the check entirely; set the same value on both sides before running
# this service anywhere beyond localhost.
INTERNAL_API_KEY=
