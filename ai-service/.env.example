PORT=4100

# Only the main backend calls this service — CORS is irrelevant to a
# server-to-server call, but set if you ever expose this directly.
CORS_ORIGIN=http://localhost:4000

# Real vision/PDF-capable Claude API access. Leave unset locally and every
# extraction call returns a clear "not configured" result instead of faking
# one — see app/services/anthropic_extraction.py.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5

# Optional shared secret the main backend sends as X-Internal-Api-Key.
# Leave unset locally to skip the check entirely; set the same value on
# both sides before exposing this service beyond localhost.
INTERNAL_API_KEY=
