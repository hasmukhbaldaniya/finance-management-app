NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# The two vars below MUST match the backend's AUTH_COOKIE_NAME/JWT_SECRET exactly.
# proxy.ts verifies the JWT itself (signature + expiry) before allowing access to
# protected routes, so a mismatch here fails safe (redirects to /login) rather than
# granting access, but is a full-lockout footgun if only one side's .env is updated.
# Required — there is no fallback; the app throws at startup if this is unset.
AUTH_COOKIE_NAME=auth_token
JWT_SECRET=change-me-to-match-backends-JWT_SECRET

# Zoho SalesIQ live-chat widget (017-zoho-salesiq-integration.md) — the full
# loader-script URL Zoho issues per account (the `src` attribute of Zoho's own
# embed snippet, e.g. https://salesiq.zohopublic.in/widget?wc=<widget-code> —
# the domain is region-specific and the widget code is a query param on it,
# not a separate value, so this holds the whole URL). Optional: if unset, the
# widget simply never loads — the app degrades gracefully, no error is thrown
# or shown.
NEXT_PUBLIC_ZOHO_SALESIQ_WIDGET_URL=
