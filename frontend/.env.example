NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# The two vars below MUST match the backend's AUTH_COOKIE_NAME/JWT_SECRET exactly.
# proxy.ts verifies the JWT itself (signature + expiry) before allowing access to
# protected routes, so a mismatch here fails safe (redirects to /login) rather than
# granting access, but is a full-lockout footgun if only one side's .env is updated.
AUTH_COOKIE_NAME=auth_token
JWT_SECRET=dev-only-insecure-secret-change-me
