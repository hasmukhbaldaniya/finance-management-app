NODE_ENV=development
PORT=4500

CORS_ORIGIN=http://localhost:3000

# reports-service has no database of its own (028-reports.md) — it forwards
# the caller's own session cookie to these two services' org-wide read
# endpoints and aggregates the results in memory.
AUTH_SERVICE_URL=http://localhost:4300
CLAIM_SERVICE_URL=http://localhost:4000

# Verify-only — must match auth-service's JWT_SECRET/AUTH_COOKIE_NAME
# byte-for-byte; a mismatch fails safe (every request here 401s).
JWT_SECRET=change-me-to-a-long-random-string
AUTH_COOKIE_NAME=auth_token
