NODE_ENV=development
PORT=4000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_management
DB_USER=postgres
DB_PASSWORD=postgres

CORS_ORIGIN=http://localhost:3000

JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRES_IN=1d
ACCESS_TOKEN_COOKIE_MAX_AGE_MS=86400000
AUTH_COOKIE_NAME=auth_token
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=30
RESET_TOKEN_EXPIRES_IN=10m

# Gmail: smtp.gmail.com / 587 / your Gmail address / a 16-char App Password (not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
REGISTRATION_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
ONBOARDING_TOKEN_EXPIRES_IN=10m

# 023's AI/ML service (Claim Management) — a standalone microservice, see
# ../ai-service. This backend never talks to Anthropic directly; it only
# needs this service's URL and an optional shared secret it sends as
# X-Internal-Api-Key (must match that service's own INTERNAL_API_KEY).
AI_SERVICE_URL=http://localhost:4100
AI_SERVICE_INTERNAL_API_KEY=
