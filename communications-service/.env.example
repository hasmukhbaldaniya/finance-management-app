NODE_ENV=development
PORT=4200

# Only auth-service/claim-service (or today's still-monolithic backend) call
# this service — CORS is irrelevant to a server-to-server call, but set if
# you ever expose this directly.
CORS_ORIGIN=http://localhost:4000

MONGO_URI=mongodb://localhost:27017/communications_service

# Gmail: smtp.gmail.com / 587 / your Gmail address / a 16-char App Password (not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-email@gmail.com

# Optional shared secret the calling service sends as X-Internal-Api-Key.
# Leave unset locally to skip the check entirely; set the same value on both
# sides before running this service anywhere beyond localhost.
INTERNAL_API_KEY=
