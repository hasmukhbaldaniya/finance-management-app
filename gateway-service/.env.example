NODE_ENV=development
PORT=4400

CORS_ORIGIN=http://localhost:3000

# The gateway is a thin routing layer only (docs/PLANS/microservices-frontend-integration-plan.md,
# section 1.0) — it forwards to whichever service actually owns each path prefix (section 1.2),
# unchanged, with no JWT verification or business logic of its own.
AUTH_SERVICE_URL=http://localhost:4300
CLAIM_SERVICE_URL=http://localhost:4000
