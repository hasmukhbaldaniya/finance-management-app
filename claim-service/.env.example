NODE_ENV=development
PORT=4000

DB_HOST=localhost
DB_PORT=5434
DB_NAME=claim_service
DB_USER=postgres
DB_PASSWORD=postgres

CORS_ORIGIN=http://localhost:3000

# Phase 3 of docs/PLANS/microservices-plan.md — this backend no longer issues
# any tokens (login/registration/onboarding moved to auth-service); only
# jwtSecret (to verify) and cookieName (to read the cookie) are still needed.
# JWT_SECRET must match auth-service's and frontend/proxy.ts's byte-for-byte.
JWT_SECRET=change-me-to-a-long-random-string
AUTH_COOKIE_NAME=auth_token

# 023's AI/ML service (Claim Management) — a standalone microservice, see
# ../ai-service. This backend never talks to Anthropic directly; it only
# needs this service's URL and an optional shared secret it sends as
# X-Internal-Api-Key (must match that service's own INTERNAL_API_KEY).
AI_SERVICE_URL=http://localhost:4100
AI_SERVICE_INTERNAL_API_KEY=

# Phase 1 of docs/PLANS/microservices-plan.md — communications-service (email
# + WhatsApp delivery). SMTP config now lives only in that service's own
# .env, not here. This backend only needs its URL and an optional shared
# secret it sends as X-Internal-Api-Key (must match that service's own
# INTERNAL_API_KEY).
COMMUNICATIONS_SERVICE_URL=http://localhost:4200
COMMUNICATIONS_SERVICE_INTERNAL_API_KEY=

# Phase 3 of docs/PLANS/microservices-plan.md — auth-service (Employee/
# Organization/Grade/Department/Role/etc.). This service has no local DB
# access to Employee/Airline anymore; the handful of cross-service reads it
# still needs (employee name/email lookups, the Airline catalog) go through
# auth-service's /api/internal/* routes, gated by the same optional
# shared-secret pattern as the other two services.
AUTH_SERVICE_URL=http://localhost:4300
AUTH_SERVICE_INTERNAL_API_KEY=
